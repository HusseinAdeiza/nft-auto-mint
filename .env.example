# ──────────────────────────────────────────────────────────
#  NFT Auto-Mint Bot — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to GitHub.
# ──────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────

# Your wallet private key (the bot will mint TO this wallet)
# Get it from MetaMask > Account Details > Export Private Key
PRIVATE_KEY=your_wallet_private_key_here

# ── RECOMMENDED ───────────────────────────────────────────

# RPC endpoint for Ethereum mainnet
# Free options: Infura (infura.io), Alchemy (alchemy.com), QuickNode
RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# OpenSea API key (free tier) — prevents rate limiting on collection lookups
# Get one at: https://docs.opensea.io/reference/api-overview
OPENSEA_API_KEY=your_opensea_api_key_here

# ── MULTI-CHAIN RPC (optional, only needed for non-Ethereum mints) ──────────

RPC_URL_POLYGON=https://polygon-rpc.com
RPC_URL_BASE=https://mainnet.base.org
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_URL_OPTIMISM=https://mainnet.optimism.io
RPC_URL_AVALANCHE=https://api.avax.network/ext/bc/C/rpc

# ── BOT SETTINGS (optional, safe defaults pre-configured) ─────────────────

# How many NFTs to mint per transaction
MINT_AMOUNT=1

# Maximum gas price you're willing to pay (in Gwei)
# Bot will wait if live gas exceeds this value
MAX_GAS_GWEI=50

# ETH to send per mint (only used as fallback if contract price() can't be read)
MINT_VALUE_ETH=0.0

# How often to poll for eligibility, in milliseconds (default: 10 seconds)
CHECK_INTERVAL=10000

# How long to wait before retrying after an error, in milliseconds
RETRY_DELAY=30000

# Max consecutive errors before the bot stops
MAX_RETRIES=5

# Stop the bot after the first successful mint (true/false)
MINT_ONCE=true
